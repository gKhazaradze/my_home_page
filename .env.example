# Copy to `.env` on the server (next to docker-compose.yml). Never commit .env.
#
# The apex domain the platform serves. The homepage is served at this domain;
# projects live at <sub>.<DOMAIN> (e.g. roadtrip.<DOMAIN>).
DOMAIN=example.com

# Contact address Let's Encrypt uses for your account + cert-expiry notices.
ACME_EMAIL=you@example.com
